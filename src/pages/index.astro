---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../sanity/imageUrl';
import { projectsQuery } from '../sanity/queries';

interface SanityImageAsset {
  _ref: string;
}
interface SanityImage {
  asset: SanityImageAsset;
  hotspot?: object;
  crop?: object;
  alt?: string;
}
interface Project {
  _id: string;
  title: string;
  slug: { current: string };
  category?: string;
  description?: string;
  mainImage?: SanityImage;
}

const projects = await sanityClient.fetch<Project[]>(projectsQuery);
---
<BaseLayout title="Pantheon Interactive" currentPath="/">
  <main class="min-h-screen pt-24 pb-16 px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/10">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug.current}`}
          class="group relative block bg-black overflow-hidden"
        >
          {project.mainImage?.asset && (
            <img
              src={urlFor(project.mainImage).width(900).auto('format').quality(80).url()}
              alt={project.mainImage.alt ?? project.title}
              width="900"
              height="600"
              loading="lazy"
              decoding="async"
              class="w-full aspect-[3/2] object-cover transition-transform duration-700 group-hover:scale-105"
            />
          )}
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/50 transition-colors duration-500 flex items-end">
            <div class="p-6 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
              <h2 class="text-xl font-medium tracking-wide">{project.title}</h2>
              {project.category && (
                <p class="text-sm text-white/60 mt-1 tracking-widest uppercase">{project.category}</p>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>

    {projects.length === 0 && (
      <div class="flex items-center justify-center min-h-[60vh]">
        <p class="text-white/40 text-sm tracking-widest uppercase">
          No projects yet —{' '}
          <a href="/studio" class="underline hover:text-white transition-colors">add one in Sanity Studio</a>
        </p>
      </div>
    )}
  </main>
</BaseLayout>
