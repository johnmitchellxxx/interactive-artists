---
const { currentPath = '/' } = Astro.props;
---
<header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-6 mix-blend-difference">
  <a href="/" class="text-white text-sm tracking-[0.2em] uppercase font-medium hover:opacity-70 transition-opacity">
    Interactive Artists
  </a>
  <nav>
    <ul class="flex gap-10">
      <li>
        <a
          href="/"
          class={`text-white text-sm tracking-[0.15em] uppercase transition-opacity ${currentPath === '/' ? 'opacity-100' : 'opacity-50 hover:opacity-100'}`}
        >
          Work
        </a>
      </li>
      <li>
        <a
          href="/about"
          class={`text-white text-sm tracking-[0.15em] uppercase transition-opacity ${currentPath === '/about' ? 'opacity-100' : 'opacity-50 hover:opacity-100'}`}
        >
          About
        </a>
      </li>
    </ul>
  </nav>
</header>
